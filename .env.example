# Local development — no pool params needed, Prisma adds them automatically if absent
DATABASE_URL="postgresql://user:password@localhost:5432/prowider"

# Production (Render free tier) — the app appends connection_limit=3&pool_timeout=30 if missing,
# but you can set them explicitly here if you want a different value:
# DATABASE_URL="postgresql://user:password@host:5432/prowider?connection_limit=3&pool_timeout=30"
